  {
    "id": "r-hadith1-bayyinah",
    "from": "hadith-1",
    "to": "verse-bayyinah",
    "type": "REFERENCES",
    "metadata": {
      "note_en": "Commands sincerity of purpose in worship.",
      "note_ar": "تأمر بالإخلاص في العبادة.",
      "verse_ar": "وَمَا أُمِرُوا إِلَّا لِيَعْبُدُوا اللَّهَ مُخْلِصِينَ لَهُ الدِّينَ"
    }
  },
  {
    "id": "r-hadith1-isra",
    "from": "hadith-1",
    "to": "verse-isra",
    "type": "REFERENCES",
    "metadata": {
      "note_en": "Ties effort to what a person is truly seeking.",
      "note_ar": "تربط السعي بما يطلبه الإنسان فعلًا.",
      "verse_ar": "وَمَنْ أَرَادَ الْآخِرَةَ وَسَعَىٰ لَهَا سَعْيَهَا وَهُوَ مُؤْمِنٌ"
    }
  },
  {
    "id": "r-hadith4-bayyinah",
    "from": "hadith-4",
    "to": "verse-bayyinah",
    "type": "REFERENCES",
    "metadata": {
      "note_en": "Sincerity in all matters.",
      "note_ar": "الإخلاص في كل الأمور.",
      "verse_ar": "وَمَا أُمِرُوا إِلَّا لِيَعْبُدُوا اللَّهَ مُخْلِصِينَ لَهُ الدِّينَ"
    }
  },
