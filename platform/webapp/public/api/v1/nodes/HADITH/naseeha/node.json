    },
    {
      "type": "commentary",
      "scholar": {
        "ar": "ابن رجب الحنبلي",
        "en": "Ibn Rajab al-Hanbali"
      },
      "workNodeId": "book-jami-ulum",
      "note": {
        "en": "Explains that naseeha — sincere advice — is the very substance of the religion: it is owed to God, His Book, His Messenger, and the Muslim community.",
        "ar": "يوضّح أن النصيحة هي جوهر الدين: حقّها واجب لله ولكتابه ولرسوله وللمسلمين عامتهم وخاصتهم."
      },
      "blockVersion": 1
    }
