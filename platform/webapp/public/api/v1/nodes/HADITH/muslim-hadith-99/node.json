  "status": "published",
  "title": {
    "ar": "اتق الله حيثما كنت",
    "en": "Fear God wherever you are"
  },
  "attributes": {
    "kind": "hadith",
    "grade": {
      "ar": "صحيح مسلم",
      "en": "Sahih Muslim"
    },
    "isnadType": "full"
  },
  "schemaVersion": 2,
  "content": [
    {
      "type": "clauses",
      "items": [
        {
          "id": "1",
          "text": {
            "ar": "اتَّقِ اللَّهَ حَيْثُمَا كُنْتَ",
            "en": "Fear God wherever you are,"
          }
        },
        {
          "id": "2",
          "text": {
            "ar": "وَأَتْبِعِ السَّيِّئَةَ الْحَسَنَةَ تَمْحُهَا",
            "en": "and follow a bad deed with a good deed which will wipe it out,"
          }
        },
        {
          "id": "3",
          "text": {
            "ar": "وَخَالِقِ النَّاسَ بِخُلُقٍ حَسَنٍ",
            "en": "and treat people with good character."
          }
        }
      ],
      "blockVersion": 1,
      "intro": {
        "ar": "عَنْ أَبِي ذَرٍّ رَضِيَ اللَّهُ عَنْهُ قَالَ: قَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ:",
        "en": "On the authority of Abu Dharr — who said: The Messenger of God ﷺ said:"
      }
    },
